# Copy to pi-jail.env and fill in your values.
# All vars here are passed directly into the container as environment variables.

# ── AI Provider API Keys ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# ── Azure OpenAI (if used) ───────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ── AWS Bedrock (if used) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# ── Git identity (used to configure git inside the container) ────────────────
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=

# ── Optional port publishing (host:container uses the same port number) ─────
# Example: PORTS=8888,9999
# Set RANDOM_PORT=true to allocate one free port starting at 9000.
# You can also add ports at launch time with: pi-jail -p 7777, pi-jail -p 7777,8888, or pi-jail -p
# Only free host ports are bound; busy ones are skipped with a warning.
PORTS=
RANDOM_PORT=false

# ── Optional host file mounts ───────────────────────────────────────────────
MVN_SETTINGS_XML="/absolute/path/to/settings.xml"
NODE_NPMRC="/absolute/path/to/.npmrc"
