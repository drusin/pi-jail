# Copy to pi-jail.env and fill in your values.
# All vars here are passed directly into the container as environment variables.

# ── AI Provider API Keys ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# ── Azure OpenAI (if used) ───────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ── AWS Bedrock (if used) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# ── Git identity (used to configure git inside the container) ────────────────
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=

# ── Optional host-command forwarding MVP ────────────────────────────────────
# Commands listed here are shimmed inside the container and executed on the
# host in the folder where the launcher was started. No path translation yet.
RUN_ON_HOST=
